# ============================================================
# CBDC Simulator — Frontend Environment Variables
# Vite only exposes variables prefixed with VITE_ to the browser.
# Do not put secrets here — this is bundled into the client JS.
# ============================================================

VITE_API_BASE_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080
VITE_APP_ENV=development
VITE_CURRENCY_SYMBOL=DD$
VITE_CURRENCY_NAME=DigitalDollar
VITE_QR_EXPIRE_SECONDS=900
