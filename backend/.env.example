# ============================================================
# CBDC Simulator — Backend Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# Generate secrets with: make generate-secrets
# ============================================================

# Server
APP_ENV=development
APP_PORT=8080
APP_VERSION=1.0.0
ALLOWED_ORIGIN=http://localhost:3000

# Security secrets — generate with: openssl rand -hex 32
# JWT_SECRET signs access tokens. Changing it invalidates all active sessions.
JWT_SECRET=REPLACE_WITH_RANDOM_32_BYTE_HEX
# JWT_ACCESS_TTL: short expiry limits damage from stolen tokens
JWT_ACCESS_TTL_SECONDS=900
# JWT_REFRESH_TTL: 7 days; backed by Redis so can be revoked
JWT_REFRESH_TTL_SECONDS=604800
# SIGNING_KEY signs transaction HMAC payloads for tamper detection
SIGNING_KEY=REPLACE_WITH_RANDOM_32_BYTE_HEX

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=cbdc_db
DB_USER=cbdc_app
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD
REDIS_DB=0

# Rate Limiting (requests per window)
RATE_LIMIT_AUTH_PER_15MIN=10
RATE_LIMIT_PAYMENT_PER_MIN=20
RATE_LIMIT_GENERAL_PER_MIN=60

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# CBDC Rules
CBDC_MAX_ISSUANCE_CENTS=100000000
CBDC_MAX_TX_CENTS=100000000
CBDC_TOTAL_SUPPLY_CAP_CENTS=10000000000

# Idempotency
IDEMPOTENCY_TTL_SECONDS=86400
